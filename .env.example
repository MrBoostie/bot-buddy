# Core
BOT_NAME=gremlin
SYSTEM_PROMPT=You are Gremlin, Boostie's sidekick. Be concise, useful, and a little chaotic.

# LLM backend mode: openclaw (uses same OpenClaw auth method) or openai (direct API key)
LLM_BACKEND=openclaw

# OpenClaw backend settings (used when LLM_BACKEND=openclaw)
OPENCLAW_AGENT_ID=main
OPENCLAW_TIMEOUT_SEC=90

# Optional direct OpenAI mode (used when LLM_BACKEND=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Safety rail: if true, Discord mode will refuse to boot unless OPENAI_API_KEY is set when LLM_BACKEND=openai
REQUIRE_OPENAI_FOR_DISCORD=true

# Operator command safety rails
OPERATOR_RELOAD_COOLDOWN_SEC=30

# Optional Discord adapter (tomorrow)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_ID=
