{
  "name": "bot-buddy",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Boostie's bot buddy: local-first chat agent with Discord adapter",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "buddy": "tsx src/buddy-cli.ts",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "discord.js": "^14.21.0",
    "dotenv": "^16.6.1",
    "openai": "^4.104.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  }
}
